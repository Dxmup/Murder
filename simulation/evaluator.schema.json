{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Simulation evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["role", "verdict", "findings", "evidence", "failure_modes", "recommendations", "scores"],
  "properties": {
    "role": {"type": "string"},
    "verdict": {"type": "string"},
    "findings": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "failure_modes": {"type": "array", "items": {"type": "string"}},
    "recommendations": {"type": "array", "items": {"type": "string"}},
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary_ending_balance", "progressive_difficulty", "article_ambiguity", "character_agency", "social_circulation", "mechanical_integrity", "report_confidence"],
      "properties": {
        "primary_ending_balance": {"type": "integer", "minimum": 1, "maximum": 10},
        "progressive_difficulty": {"type": "integer", "minimum": 1, "maximum": 10},
        "article_ambiguity": {"type": "integer", "minimum": 1, "maximum": 10},
        "character_agency": {"type": "integer", "minimum": 1, "maximum": 10},
        "social_circulation": {"type": "integer", "minimum": 1, "maximum": 10},
        "mechanical_integrity": {"type": "integer", "minimum": 1, "maximum": 10},
        "report_confidence": {"type": "integer", "minimum": 1, "maximum": 10}
      }
    }
  }
}
