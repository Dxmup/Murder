{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$comment": "Legacy Version 1 evaluator schema. Do not use for Version 2.",
  "title": "Legacy V1 simulation evaluation",
  "type": "object",
  "additionalProperties": false,
  "required": ["role", "verdict", "findings", "evidence", "risks", "recommendations", "scores"],
  "properties": {
    "role": {"type": "string"},
    "verdict": {"type": "string"},
    "findings": {"type": "array", "items": {"type": "string"}},
    "evidence": {"type": "array", "items": {"type": "string"}},
    "risks": {"type": "array", "items": {"type": "string"}},
    "recommendations": {"type": "array", "items": {"type": "string"}},
    "scores": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mystery_balance", "character_agency", "mechanical_integrity", "human_ai_ambiguity", "report_confidence"],
      "properties": {
        "mystery_balance": {"type": "integer", "minimum": 1, "maximum": 10},
        "character_agency": {"type": "integer", "minimum": 1, "maximum": 10},
        "mechanical_integrity": {"type": "integer", "minimum": 1, "maximum": 10},
        "human_ai_ambiguity": {"type": "integer", "minimum": 1, "maximum": 10},
        "report_confidence": {"type": "integer", "minimum": 1, "maximum": 10}
      }
    }
  }
}
